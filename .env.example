NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Local development may use either the VITE_* names below or the legacy NEXT_PUBLIC_* names above.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Required in production for Google OAuth redirect URLs.
# Supabase will redirect to ${VITE_APP_DOMAIN}/app after sign-in.
# Defaults to https://grantedai.app in vite.config.ts — set this for custom domains or staging.
VITE_APP_DOMAIN=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Local dev defaults to 5001 because macOS often reserves 5000 for Control Center/AirPlay.
# Set this explicitly if you need another local port.
# PORT=5001

# Required when NODE_ENV=production (Express sessions & Passport local auth).
SESSION_SECRET=

# Set to `1` to skip Postgres-backed sessions even when DATABASE_URL is set
# (e.g. tests). Sessions fall back to in-memory storage (non-persistent).
# DISABLE_PG_SESSION_STORE=

DOCUMENTS_BUCKET=documents
DOCUMENT_WORKER_API_KEY=

# Required when using the Vercel cron route GET /api/cron/process-documents.
# Set the same value in your Vercel project env and vercel.json cron config.
CRON_SECRET=

OPENAI_API_KEY=

# Generation model used by the RAG pipeline. Defaults to gpt-4o-mini.
# GRANTED_DEFAULT_MODEL=gpt-4o-mini

# Embedding model for document chunks. Defaults to text-embedding-3-small (1536-dim).
# DOCUMENT_EMBEDDING_MODEL=text-embedding-3-small

# Image model for `npm run marketing:image`. Defaults to gpt-image-1.
# GRANTED_IMAGE_MODEL=gpt-image-1

# Not currently used — reserved for future multi-provider support.
# ANTHROPIC_API_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=price_1TTUzQCy6PByA3b62RruIZL4
STRIPE_PRO_PAYMENT_LINK_URL=https://buy.stripe.com/test_aFa6oG20Q55y2Kz0ureEo00

# Upper bound for unpdf PDF.js extraction (milliseconds).
# PDF_PARSE_TIMEOUT_MS=

# Log redacted copies of HTTP bodies only when DEBUG_VERBOSE_HTTP=1.
# DEBUG_VERBOSE_HTTP=

# Not currently used — provider selection is not yet implemented (OpenAI only).
# GRANTED_DEFAULT_PROVIDER=openai

# Auth smoke test only. Use a valid Supabase user access token.
SUPABASE_TEST_ACCESS_TOKEN=

# Optional auth smoke target. Defaults to http://localhost:${PORT:-5001} in development.
AUTH_SMOKE_BASE_URL=

# Notion knowledgebase sync (used by the doc-keeper agent / /sync-docs).
# See docs/NOTION_SYNC.md for setup. Leave blank to disable Notion publishing
# (doc-keeper falls back to printing a paste-ready block).
NOTION_TOKEN=
NOTION_KB_PAGE_ID=
